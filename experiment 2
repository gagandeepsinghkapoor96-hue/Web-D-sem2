<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechStore</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f5f5f5;
        }

        .navbar {
            background-color: #1f2329;
        }

        .navbar-brand,
        .nav-link {
            color: white !important;
        }

        .card img {
            height: 220px;
            object-fit: contain;
            padding: 15px;
        }

        footer {
            background: #1f2329;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 50px;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">

            <a class="navbar-brand fw-bold" href="#">TechStore</a>

            <button class="navbar-toggler bg-light" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" href="#">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Products</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Contact</a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <!-- Product Cards -->
    <div class="container my-5">
        <div class="row g-4">

            <!-- Laptop -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <img src="laptop.png" class="card-img-top" alt="Laptop">

                    <div class="card-body">
                        <h4 class="card-title">Laptop</h4>
                        <p class="card-text">High Performance Laptop</p>

                        <h5>
                            ₹50,000
                            <span class="badge bg-success">New</span>
                        </h5>

                        <button class="btn btn-primary mt-2"
                            data-bs-toggle="modal"
                            data-bs-target="#laptopModal">
                            View Details
                        </button>
                    </div>
                </div>
            </div>

            <!-- Mobile -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <img src="mobile.png" class="card-img-top" alt="Mobile">

                    <div class="card-body">
                        <h4 class="card-title">Mobile</h4>
                        <p class="card-text">Latest Smartphone</p>

                        <h5>
                            ₹30,000
                            <span class="badge bg-danger">Sale</span>
                        </h5>

                        <button class="btn btn-primary mt-2"
                            data-bs-toggle="modal"
                            data-bs-target="#mobileModal">
                            View Details
                        </button>
                    </div>
                </div>
            </div>

            <!-- Headphones -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <img src="headphone.png" class="card-img-top" alt="Headphones">

                    <div class="card-body">
                        <h4 class="card-title">Headphones</h4>
                        <p class="card-text">Noise Cancelling</p>

                        <h5>
                            ₹5,000
                            <span class="badge bg-success">New</span>
                        </h5>

                        <button class="btn btn-primary mt-2"
                            data-bs-toggle="modal"
                            data-bs-target="#headphoneModal">
                            View Details
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Laptop Modal -->
    <div class="modal fade" id="laptopModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Laptop Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    High-performance laptop with fast processor,
                    SSD storage and long battery life.
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Mobile Modal -->
    <div class="modal fade" id="mobileModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Mobile Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Latest smartphone with powerful camera,
                    AMOLED display and fast charging support.
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Headphone Modal -->
    <div class="modal fade" id="headphoneModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Headphone Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Premium wireless headphones with active
                    noise cancellation and deep bass.
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        © 2026 TechStore | Follow us on social media
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
