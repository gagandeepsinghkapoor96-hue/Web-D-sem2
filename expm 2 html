<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechStore</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">TechStore</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Products</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Products Section -->
    <div class="container mt-5">
        <div class="row">

            <!-- Card 1 -->
            <div class="col-lg-4 col-md-6 col-12 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1496181133206-80ce9b88a853" height="220" class="card-img-top">
                    <div class="card-body">
                        <h5>Laptop</h5>
                        <p>High Performance Laptop</p>
                        <h6>₹50,000 <span class="badge bg-success">New</span></h6>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#m1">
                            View Details
                        </button>
                    </div>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="col-lg-4 col-md-6 col-12 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9" height="220" class="card-img-top">
                    <div class="card-body">
                        <h5>Mobile</h5>
                        <p>Latest Smartphone</p>
                        <h6>₹30,000 <span class="badge bg-danger">Sale</span></h6>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#m2">
                            View Details
                        </button>
                    </div>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="col-lg-4 col-md-6 col-12 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e" height="220" class="card-img-top">
                    <div class="card-body">
                        <h5>Headphones</h5>
                        <p>Noise Cancelling</p>
                        <h6>₹5,000 <span class="badge bg-success">New</span></h6>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#m3">
                            View Details
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Modal 1 -->
    <div class="modal fade" id="m1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Laptop Details</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    16GB RAM, SSD Storage, Fast Performance
                </div>
            </div>
        </div>
    </div>

    <!-- Modal 2 -->
    <div class="modal fade" id="m2">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Mobile Details</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    High Camera Quality Smartphone
                </div>
            </div>
        </div>
    </div>

    <!-- Modal 3 -->
    <div class="modal fade" id="m3">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Headphones Details</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Best Sound Quality with Deep Bass
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center p-3">
        <p>© 2026 TechStore | Follow us on Social Media</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="script.js"></script>
</body>
</html>
